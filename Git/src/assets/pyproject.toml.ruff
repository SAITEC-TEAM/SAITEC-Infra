[tool.black]
line-length = 88
target-version = ["py{{$PYTHON_VERSION_REAL_NOPOINT}}"]

[tool.ruff]
select = ["E", "F", "I", "D", "B", "UP"]
ignore = ["D100"]

[tool.ruff.pydocstyle]
convention = "google"

[tool.ruff.lint.per-file-ignores]
"tests/*" = ["D"]

[tool.ruff.format]
quote-style = "double"
indent-style = "space"